#!/usr/bin/env python3
"""Create a blank tracker CSV for the Summer Income Planner skill.

This helper is deterministic, local-only, and safe: it does not use the network,
does not read secrets, and does not execute shell commands.
"""

from __future__ import annotations

import argparse
import csv
from pathlib import Path

COLUMNS = [
    "week",
    "date",
    "hours_planned",
    "hours_done",
    "offer_tested",
    "outreach_count",
    "conversations",
    "leads",
    "projects_or_orders",
    "target_income",
    "actual_income",
    "expenses",
    "net_actual",
    "blockers",
    "lessons_learned",
    "next_action",
]


def positive_int(value: str) -> int:
    try:
        parsed = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError("weeks must be an integer") from exc
    if parsed < 1 or parsed > 12:
        raise argparse.ArgumentTypeError("weeks must be between 1 and 12")
    return parsed


def write_tracker(path: Path, weeks: int) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", newline="", encoding="utf-8") as handle:
        writer = csv.DictWriter(handle, fieldnames=COLUMNS)
        writer.writeheader()
        for week in range(1, weeks + 1):
            row = {column: "" for column in COLUMNS}
            row["week"] = week
            writer.writerow(row)


def main() -> int:
    parser = argparse.ArgumentParser(description="Create a blank summer income tracker CSV.")
    parser.add_argument("--weeks", type=positive_int, default=6, help="Number of weeks to include. Default: 6.")
    parser.add_argument("--out", default="summer_income_tracker.csv", help="Output CSV path.")
    args = parser.parse_args()

    output_path = Path(args.out)
    write_tracker(output_path, args.weeks)
    print(output_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
